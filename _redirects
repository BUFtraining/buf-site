/contact-us              /contact-us/           301
/mobility-sessions       /mobility-sessions/    301
/privacy-policy          /privacy-policy/       301
/rates                   /rates/                301
/reviews                 /reviews/              301
/trainers                /trainers/             301
/blog                    /blog/                 301

# Legacy Wix blog URLs (Wix used /post/{slug} structure)
# Catch-all wildcard handles any old Wix post URL → homepage
/post/*                  /                      301

